# ── Telegram ──────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token
# Список Telegram ID с доступом (через запятую). Пусто = доступ всем.
ALLOWED_USER_IDS=
# ID администратора (управление пользователями, смена ключа)
ADMIN_USER_ID=0

# ── RouterAI (Claude для обработки текста) ───────────────────────
# Ключ с https://routerai.ru — используется для всех текстовых задач
ROUTERAI_API_KEY=your_routerai_key
ROUTERAI_BASE_URL=https://routerai.ru/api/v1
TEXT_MODEL=anthropic/claude-opus-4.8-fast

# ── OpenAI (эмбеддинги, распознавание голоса, анализ изображений) ─
OPENAI_API_KEY=sk-your_openai_key
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
WHISPER_MODEL=whisper-1
VISION_MODEL=gpt-4o-mini

# ── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=second_brain
POSTGRES_USER=brain
POSTGRES_PASSWORD=change_me_in_production

# ── Qdrant ───────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=notes
